# ── Neon PostgreSQL ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/docintel?ssl=require

# ── Upstash Redis ────────────────────────────────
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# ── Cloudflare R2 ────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET=docintel-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── App ──────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string
ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:5173"]

# ── Tesseract (Render sets this automatically) ───
TESSERACT_CMD=tesseract
